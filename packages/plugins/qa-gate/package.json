{
  "name": "@paperclipai/plugin-qa-gate",
  "version": "0.1.1",
  "description": "Paperclip plugin that blocks done status transitions on code-delivery issues unless a @qa-agent PASS comment exists",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts"
  },
  "paperclipPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js"
  },
  "scripts": {
    "prebuild": "node ../../../scripts/ensure-plugin-build-deps.mjs",
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "pnpm --filter @paperclipai/plugin-sdk build && tsc --noEmit",
    "test": "vitest run --config ./vitest.config.ts"
  },
  "dependencies": {
    "@paperclipai/plugin-sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  }
}
